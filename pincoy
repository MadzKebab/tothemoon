        <script>
(function () {
  const pw  = document.getElementById('password_field');     // name="Password"
  const pw2 = document.getElementById('ConfirmedPassword');  // name="ConfirmedPassword"
  const ph  = document.getElementById('Phone');              // name="Phone"
  const wa  = document.getElementById('WhatsApp');           // name="WhatsApp"

  function mirrorOneWay(srcEl, dstEl) {
    if (!srcEl || !dstEl || srcEl === dstEl) return;

    let dstTouched = false;
    const markTouched = (e) => { if (e.isTrusted) dstTouched = true; };
    ['focus','input','paste','change','keydown','keyup','mousedown','touchstart']
      .forEach(ev => dstEl.addEventListener(ev, markTouched, { passive:true }));

    const copyNow = () => {
      if (dstTouched) return;                
      const next = srcEl.value || '';
      if (dstEl.value !== next) {
        dstEl.value = next;
        
        dstEl.dispatchEvent(new Event('input',  { bubbles:true }));
        dstEl.dispatchEvent(new Event('change', { bubbles:true }));
      }
    };

    
    ['input','keyup','paste','change','blur'].forEach(ev =>
      srcEl.addEventListener(ev, () => setTimeout(copyNow, 0), { passive:true })
    );

    
    setTimeout(copyNow, 50);
  }


  mirrorOneWay(pw,  pw2); // Password -> ConfirmedPassword
  mirrorOneWay(ph,  wa);  // Phone -> WhatsApp
})();
</script>
