    <script>
        (function () {
        const jsonEl = document.getElementById('bv-jsonld-reviews-data');
        if (!jsonEl) {
            console.error('[reviews] JSON-LD tidak ditemukan');
            return;
        }

        let raw;
        try {
            raw = JSON.parse(jsonEl.textContent);
        } catch (e) {
            console.error('[reviews] JSON-LD invalid', e);
            return;
        }

        function formatRelativeDate(iso) {
            if (!iso) return '';
            const d = new Date(iso);
            const diff = Math.floor((Date.now() - d.getTime()) / 86400000);

            if (diff <= 0) return 'hari ini';
            if (diff === 1) return 'satu hari yang lalu';
            if (diff < 30) return diff + ' hari yang lalu';
            if (diff < 365) return Math.floor(diff / 30) + ' bulan yang lalu';
            return Math.floor(diff / 365) + ' tahun yang lalu';
        }

        window.REVIEWS = (raw.review || []).map((r, i) => {
            const iso = (r.datePublished || r.dateCreated || '').slice(0, 10);

            return {
            id: i + 1,
            author: r.author?.name || 'Anonymous',
            rating: Number(r.reviewRating?.ratingValue || 0),
            title: r.headline || '',
            body: r.reviewBody || '',
            dateISO: iso,
            dateText: formatRelativeDate(iso),
            locale: 'intl'
            };
        });

        console.log('[reviews] data siap:', window.REVIEWS);
        console.table(window.REVIEWS);
        })();
        </script>
