                                  ? slider_config.items
                                  : 1;
                              if (slider_config.transition != "slide") {
                                itemsCount = 1;
                              }

                              let windowWidth = $(window).width();

                              if (windowWidth < 600) {
                                itemsCount =
                                  parseInt(slider_config.items_brk1) || 1;
                              } else if (windowWidth < 1000) {
                                itemsCount =
