rs","level":"A"}]},"phoneInfo":{"title":"Phone","type":"phoneInfo","formatTelephoneList":[{"phoneFunction":"Ticket inquiry","phoneList":[{"phoneNumber":"+81-6-64654005"},{"phoneNumber":"+81-570-200606"}]}]},"serviceFacilityInfo":{"title":"Available amenities","type":"serviceFacility","serviceFacilityList":[{"facilityName":"Phone charging","facilityCode":"3","iconUrl":"\u0026#xf012a;","facilityInfoList":[{"facilityItemList":[{"itemCode":5,"itemName":"Note(s)","itemValue":"The park has mobile battery rental stations where you can borrow phone batteries as needed and simply return them after use.\n*To use this service, you need to download and register on the mobile battery sharing service charging point app.\n*You can download the dedicated app by scanning the QR code at the mobile battery rental stations within the park.\n\nAbout usage fees and service:\nPlease check the dedicated app for usage fees.\nFor service inquiries, please check the dedicated app or contact the charging point support center through the app.\nService may be suspended without prior notice due to circumstances.\n\nLocations:\n1. Inside lockers in front of the entrance\n2. In front of restrooms beside Kinopio Cafe™\n3. In front of restrooms next to Elmo's Go Go Skateboard\n4. In front of men's restroom near Joe's House\n5. In front of Friendly Village restrooms\n6. In front of restrooms beside Louise N.Y. Pizza\n7. In front of dressing rooms near Manhattan Theater\n8. In front of lounge at Lombard's Landing™"},{"itemCode":9,"itemName":"Type","itemValue":"Mobile phone battery rental service"}]}]},{"facilityName":"Luggage storage","facilityCode":"4","iconUrl":"\u0026#xf0122;","facilityInfoList":[{"facilityItemList":[{"itemCode":2,"itemName":"Reference price","itemValue":"JPY 400–1,500"},{"itemCode":3,"itemName":"Address","itemValue":"On the side of the parking lot, left side in front of the main entrance."},{"itemCode":9,"itemName":"Type","itemValue":"Coin-operated locker service"}]}]},{"facilityNa