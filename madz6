            <script id="__NEXT_DATA__" type="application/json"
                crossorigin="anonymous">{"props":{"pageProps":{"initialState":{"cargoContext":{"group":"","currency":"IDR","locale":"en-XX","lang":"en","site":""},"appData":{"type":"poi","hotScore":"10","aid":"14895","sid":"1621245","cid":"1779298019577.b50223Fmall8","tagId":"","currency":"IDR","userAgent":"Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/148.0.0.0 Safari/537.36","ifIsBot":false,"isLighthouse":false,"uniqueKey":"","overviewData":{"ResponseStatus":{"Timestamp":"","Ack":"Success","Errors":[]},"result":0,"useLocalCache":false,"basicInfo":{"poiId":81012,"bizId":22197,"poiType":"SIGHT","poiTypeValue":3,"poiName":"Universal Studios Japan","nameNotMatchLocale":false,"isFree":false,"poiSubtitleName":"ユニバーサル・スタジオ・ジャパン","poiEnglishName":"Universal Studios Japan","tagList":["Amusement parks","Night view"],"tagInfoList":[{"name":"Amusement parks"},{"name":"Night view"}],"address":"2 Chome-1-33 Sakurajima, Konohana Ward, Osaka, 554-0031, Japan","introduction":"\u003cul\u003e\u003cli\u003eThere are thrilling rides themed around Hollywood's superstar movies, fantastic performances by popular cartoon characters, and more, so everyone can have fun!\u003c/li\u003e\u003c/ul\u003e\u003cp\u003e\u003cbr\u003e\u003c/p\u003e\u003cul\u003e\u003cli\u003eFeaturing the world's first Nintendo theme park, experience the world of Super Mario in an immersive way!\u003c/li\u003e\u003c/ul\u003e\u003cp\u003e\u003cbr\u003e\u003c/p\u003e\u003cul\u003e\u003cli\u003e\u003cspan style=\"color: rgb(16, 34, 71); font-size: 12px;\"\u003eFestive limited parades and float tours! Everyone is a protagonist in this enthusiastic parade where everyone is full of passion and vigor!\u003c/span\u003e\u003c/li\u003e\u003c/ul\u003e\u003cp style=\"text-align: justify;\"\u003e\u003cbr\u003e\u003c/p\u003e\u003cp style=\"text-align: justify;\"\u003eUniversal Studios Japan (“USJ”) in Osaka is one of the world's five Universal Studios theme parks, which opened for business in 2001 and is a classic and wonderful world of fun in the hearts of many visitors. It is similar in design to Universal Studios Orlando in the U.S., with popular parks such as Jurassic Park, Hollywood, and Waterworld, and more than 60 fun-filled attractions. With these attractions, you can enjoy a day of fun and entertainment at Universal Studios Japan.\u003c/p\u003e\u003cp style=\"text-align: justify;\"\u003e\u003cimg src=\"https://dimg04.tripcdn.com/images/0354o12000g6hgp9sE8E7.jpg\"\u003e\u003c/p\u003e\u003cp style=\"text-align: justify;\"\u003eUniversal Studios Japan is also home to popular themed IP parks such as “Super Nintendo World (Mario/Super Mario)”, “Minion Park” and “The Wizarding World of Harry Potter”. Whether it's interacting with the minions, riding on Mario Kart, or traveling through the Wizarding World of Hogwarts, it's an unforgettable experience that is full of excitement.\u003c/p\u003e\u003cp style=\"text-align: justify;\"\u003e\u003cimg src=\"https://dimg04.tripcdn.com/images/1lo4h12000dne4eix7C4B.jpg\"\u003e\u003c/p\u003e\u003cp style=\"text-align: justify;\"\u003e△“Super Nintendo World” is the world's first Nintendo theme park built by Nintendo in cooperation with Universal Studios Japan. With the globally popular Super Mario as the protagonist, the game's Kuba Castle, Princess Brigitte's Castle, and the Mushroom Kingdom are reproduced 1:1 in a super-realistic way, providing immersive experiences of the world of Super Mario!\u003c/p\u003e\u003cp style=\"text-align: justify;\"\u003e\u003cimg src=\"https://dimg04.tripcdn.com/images/0104t120003u2sw0v5E11.jpg\"\u003e\u003c/p\u003e\u003cp style=\"text-align: justify;\"\u003e△The “Freeze Ray Sliders” and “Despicable Me: Minion Mayhem” will get you involved in a huge farce and heat wave with the minions! The Minions have finally fulfilled their ambitions! All of humanity will be a part of the mayhem at the Minion Park!\u003c/p\u003e\u003cp style=\"text-align: justify;\"\u003e\u003cimg src=\"https://dimg04.tripcdn.com/images/0105x120003u2suvkF942.jpg\"\u003e\u003c/p\u003e\u003cp style=\"text-align: justify;\"\u003e△Embracing a variety of areas with unique characteristics, wonderment and surprise, Universal Studios Japan covers a whole spectrum of world-class entertainment through thrilling rides and shows themed on blockbuster Hollywood movies, as well as seasonal events for all ages to enjoy.\u003c/p\u003e\u003cp style=\"text-align: justify;\"\u003eThe Wizarding World of Harry Potter™ will reproduce the world from the Harry Potter™ stories, bringing it to life on a phenomenal scale at Universal Studios Japan.\u003c/p\u003e","playSpendTime":"1 day","telephone":["+81664654005","+81570200606"],"formatTelephoneList":[{"phoneFunction":"Ticket inquiry","phoneList":[{"phoneNumber":"+81-6-64654005"},{"phoneNumber":"+81-570-200606"}]}],"coordinate":{"coordinateType":"GCJ02","latitude":34.665677,"longitude":135.432319},"hotScore":"10","hasAskWay":true,"detailUrl":"https://www.whygo.com.tw/terms?poiType=3\u0026rankingId=100001428060\u0026curr=IDR\u0026locale=en-XX\u0026scene=basic","appUrl":"/rn_ibu_traveling/_crn_config?CRNModuleName=RN_Product_IBU_Traveling\u0026CRNType=1\u0026transparentstatusbar=1\u0026initialPage=POIDetail\u0026sightId=81012\u0026poiType=3\u0026rankingId=100001428060","onlineUrl":"https://www.whygo.com.tw/terms?poiType=3\u0026rankingId=100001428060\u0026curr=IDR\u0026locale=en-XX\u0026scene=basic","useNewMap":false,"alias":["Universal Studios Osaka","Nintendo","USJ"],"isActivityPoi":false,"isJumpActivityDetail":false},"districtInfo":{"coordinate":{"coordinateType":"GCJ02","latitude":34.665677,"longitude":135.432319},"districtId":293,"districtName":"Osaka","districtEnglishName":"Osaka","inChina":false,"isOverseas":true},"favorite":{"isFavorite":false,"favoriteId":"0","favoriteCount":48930,"isActivityFavorite":false},"noticeInfo":{"noticeTitle":"","noticeDetailList":[{"title":"Show \u0026 Attraction Closure Information","level":"A","content":"\u00