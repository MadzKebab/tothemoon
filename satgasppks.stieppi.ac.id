            _BISConfig.product = { "id": 8764696363060, "title": "API แท้ 2026 ไม่ผ่านกลาง! สล็อตเว็บตรง ทรูวอเลท RTP สด 99% แตกหนัก โอนไว", "handle": "felt-cute-2026-lineup-tee", "description": "\u003cp\u003eHeavyweight tee in vintage black, featuring original felt-inspired logo art printed on the front and the 2026 Coachella lineup printed on the back. 100% Pre-Shrunk Cotton. Unisex, relaxed fit.\u003c\/p\u003e\n\u003cp\u003e\u003cmeta charset=\"utf-8\"\u003ePrinted on \u003ca href=\"https:\/\/www.bellacanvas.com\/\" title=\"BELLA+CANVAS\" rel=\"noopener\" target=\"_blank\"\u003eBELLA+CANVAS\u003c\/a\u003e.\u003c\/p\u003e\n\u003cp\u003e\u003cspan data-olk-copy-source=\"MessageBody\"\u003eFelt icons by Andrea Love.\u003c\/span\u003e\u003c\/p\u003e\n\u003cdiv class=\"drop-hide\"\u003e\n\u003cdiv class=\"drop-element\"\u003e\n\u003cp class=\"show-more-button\"\u003eSustainability Features \u003cspan\u003e+\u003c\/span\u003e\u003c\/p\u003e\n\u003cdiv class=\"hidden-text\"\u003e\n\u003cul\u003e\n\u003cli\u003eSustainable Manufacturing: This product was made using sustainable manufacturing processes with \u003ca href=\"https:\/\/www.bluesign.com\/en\/company\/impact\/\" target=\"_blank\"\u003eBlue Sign certified\u003c\/a\u003e dyes, efficient dye houses that adhere to the state of California's EPA regulations around wastewater treatment and usage, and cutting facilities in Los Angeles that run on partial solar power with comprehensive recycling programs for paper waste and fabric scraps.\u003c\/li\u003e\n\u003cli\u003eSocially Conscious Manufacturing: This product was made in a facility that is \u003ca href=\"https:\/\/wrapcompliance.org\/en\/about\/what-we-do\/12-principles\/\" target=\"_blank\"\u003eWRAP certified\u003c\/a\u003e and accredited by the \u003ca href=\"https:\/\/www.fairlabor.org\/\" target=\"_blank\"\u003eFair Labor Association\u003c\/a\u003e.\u003c\/li\u003e\n\u003c\/ul\u003e\n\u003c\/div\u003e\n\u003c\/div\u003e\n\u003c\/div\u003e", "published_at": "20