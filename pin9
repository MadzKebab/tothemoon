    // ========== FALLING GLITTER & CANDY PARTICLES ==========
    function createFallingParticles() {
        const container = document.getElementById('particleContainer');
        const particleTypes = ['glitter', 'candy', 'star'];
        const colors = ['#FFD700', '#FFA500', '#FF69B4', '#4ECDC4', '#FFE66D', '#FF6B6B', '#A8E6CF', '#FFB347'];
        
        setInterval(() => {
            // Create 5-15 particles per frame
            const count = Math.floor(Math.random() * 12) + 5;
            
            for (let i = 0; i < count; i++) {
                const type = particleTypes[Math.floor(Math.random() * particleTypes.length)];
                const particle = document.createElement('div');
                particle.classList.add(type);
                
                // Random position
                particle.style.left = Math.random() * 100 + '%';
                
                // Random size (variasi)
                if (type === 'glitter') {
                    const size = Math.random() * 6 + 3;
                    particle.style.width = size + 'px';
                    particle.style.height = size + 'px';
                    particle.style.background = `radial-gradient(circle, ${colors[Math.floor(Math.random() * colors.length)]}, ${colors[Math.floor(Math.random() * colors.length)]})`;
                } else if (type === 'candy') {
                    const size = Math.random() * 8 + 5;
                    particle.style.width = size + 'px';
                    particle.style.height = size + 'px';
                    particle.style.background = `linear-gradient(135deg, ${colors[Math.floor(Math.random() * colors.length)]}, ${colors[Math.floor(Math.random() * colors.length)]})`;
                } else {
                    const size = Math.random() * 4 + 2;
                    particle.style.width = size + 'px';
                    particle.style.height = size + 'px';
                }
                
                // Random duration
                const duration = Math.random() * 5 + 3;
                particle.style.animationDuration = duration + 's';
                
                // Random delay
                particle.style.animationDelay = Math.random() * 0.5 + 's';
                
                container.appendChild(particle);
                
                // Remove after animation
                setTimeout(() => {
                    if (particle && particle.remove) {
                        particle.remove();
                    }
                }, duration * 1000);
            }
        }, 400);
        
        // Tambahin stars static yang twinkle di background
        for (let i = 0; i < 80; i++) {
            const star = document.createElement('div');
            star.classList.add('star');
            star.style.left = Math.random() * 100 + '%';
            star.style.top = Math.random() * 100 + '%';
            star.style.animationDuration = Math.random() * 3 + 1 + 's';
            star.style.animationDelay = Math.random() * 5 + 's';
            star.style.width = Math.random() * 3 + 1 + 'px';
            star.style.height = star.style.width;
            container.appendChild(star);
        }
    }
    
    createFallingParticles();
